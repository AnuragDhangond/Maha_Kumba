spring.application.name=kumbh-backend

# Database
spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/kumbh_mela}
spring.datasource.username=${DB_USER:root}
spring.datasource.password=${DB_PASSWORD:Gaurav@9022}
spring.datasource.driver-class-name=${DB_DRIVER:com.mysql.cj.jdbc.Driver}

# Connection Pool Settings
spring.datasource.hikari.maximum-pool-size=30
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.idle-timeout=30000
spring.datasource.hikari.connection-timeout=20000
spring.datasource.hikari.max-lifetime=1800000

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=${DB_DIALECT:org.hibernate.dialect.MySQL8Dialect}
spring.jpa.open-in-view=false

# Server
server.port=8080

# Security
jwt.secret=kumbh_secret_key_123456789012345678901234567890

# Suppress PageImpl serialization warning (keep backwards compatibility for frontend)
logging.level.org.springframework.data.web.config=ERROR

# Suppress Spring Boot's default generated password log
spring.security.user.name=kumbh_admin
spring.security.user.password=kumbh_admin_disabled

# Multipart Upload Settings
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB